---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/mission', label: 'Missions' },
  { href: '/community', label: 'Community' },
  { href: '/explore', label: 'Explore' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="header">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-[70px] md:h-[96px]">
      <!-- Logo - Text only -->
      <a href="/" class="header-logo-text flex-shrink-0 flex items-center">
        <span class="text-2xl md:text-3xl font-bold text-gold-500 tracking-wider">FONE</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8 lg:gap-12">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-[500] tracking-[0.08em] uppercase transition-colors duration-300 hover:text-accent ${
              currentPage === link.href
                ? 'text-accent'
                : 'text-gray-400'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <div class="flex items-center gap-4">
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg transition-colors hover:bg-dark-700"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              id="menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
            <path
              id="close-icon"
              class="hidden"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 right-0 bg-dark-800/95 backdrop-blur-lg border-t border-dark-600"
  >
    <div class="container-custom py-6">
      <div class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-lg font-medium py-2 transition-colors ${
              currentPage === link.href
                ? 'text-accent'
                : 'text-gray-300 hover:text-accent'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- Header Background on Scroll -->
<style>
  header.scrolled {
    @apply bg-dark-900/90 backdrop-blur-lg border-b border-dark-700;
  }
</style>

<script>
  // Header scroll effect
  const header = document.getElementById('header');
  
  function updateHeader() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', updateHeader);
  updateHeader();

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
