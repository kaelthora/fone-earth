---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  currentPage?: string;
  title?: string;
  description?: string;
  ogImage?: string;
}

const { currentPage = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>FONE | Foundation of New Earth</title>
    <meta name="title" content="FONE | Foundation of New Earth" />
    <meta name="description" content="Building the future for a reunited humanity. Our mission: Remember who we are and build a New Earth based on Respect, Universal Love, and Equity." />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.fone.earth/" />
    <meta property="og:title" content="FONE | Foundation of New Earth" />
    <meta property="og:description" content="Building the future for a reunited humanity. Respect. Universal Love. Equity." />
    <meta property="og:image" content="https://www.fone.earth/og-image.jpg" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://www.fone.earth/" />
    <meta property="twitter:title" content="FONE | Foundation of New Earth" />
    <meta property="twitter:description" content="Remember who we are. Build a New Earth." />
    <meta property="twitter:image" content="https://www.fone.earth/og-image.jpg" />

    <!-- SEO Meta Tags -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="FONE" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class:list={['min-h-screen', 'flex', 'flex-col', currentPage === '/community' && 'community-page']}>
    <div class="cosmic-background" aria-hidden="true"></div>
    <div class="site-content">
      <Header currentPage={currentPage} />
      <main class:list={[currentPage === '/community' ? 'community-main-portals' : 'flex-grow']}>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      const root = document.documentElement;

      let beat = 6;
      function updateBeat() {
        root.style.setProperty("--cosmic-beat-duration", beat + "s");
      }

      updateBeat();

      setInterval(() => {
        beat = 5.5 + Math.random() * 1.5;
        updateBeat();
      }, 8000);

      let lastMove = Date.now();
      document.addEventListener("mousemove", () => {
        lastMove = Date.now();
      });

      setInterval(() => {
        const idle = Date.now() - lastMove;
        if (idle > 5000) {
          root.style.setProperty("--cosmic-intensity", "1.2");
        } else {
          root.style.setProperty("--cosmic-intensity", "1");
        }
      }, 2000);
    </script>
  </body>
</html>
