---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Open a channel. Not every message is a question — some are simply signals. Speak freely. Every message is received with respect."
  currentPage="/contact"
>
  <article class="contact-page contact-wrapper">
    <div class="contact-bg" aria-hidden="true">
      <div class="contact-cosmic-breath" aria-hidden="true"></div>
      <div class="contact-stars-rare" aria-hidden="true"></div>
    </div>
    <div class="signal-beam" aria-hidden="true"></div>
    <div class="cosmic-response" aria-hidden="true"></div>
    <div class="cosmic-passage" aria-hidden="true"></div>
    <div class="cosmic-stars" aria-hidden="true"></div>
    <div class="starfield" aria-hidden="true"></div>
    <div class="shooting-star" aria-hidden="true"></div>
    <div class="contact-stars" aria-hidden="true"></div>

    <div class="contact-content contact-hero">
      <div class="contact-particles" aria-hidden="true">
        <span class="contact-particle"></span>
        <span class="contact-particle"></span>
        <span class="contact-particle"></span>
        <span class="contact-particle"></span>
        <span class="contact-particle"></span>
        <span class="contact-particle"></span>
      </div>
      <div class="contact-threshold-glow" aria-hidden="true"></div>
      <div class="contact-threshold-inner">
        <div class="contact-title-glow" aria-hidden="true"></div>
        <h1 class="contact-reveal-text contact-title">
          <span>OPEN </span>
          <span>A </span>
          <span>CHANNEL</span>
        </h1>
        <div class="contact-threshold-text">
          <p>Not every message is a question.<br />Some are simply signals.</p>
          <p>Signals that two paths have recognized each other.</p>
        </div>
      </div>

      <div class="contact-channel">
        <p class="contact-channel-intro">
          Speak freely.<br />
          Every message is received with respect.
        </p>
        <form class="contact-form" action="/api/sendEmail.json" method="POST" id="contact-form">
          <div class="contact-field">
            <label for="contact-name" class="contact-label">Your Name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              class="contact-input"
              required
            />
          </div>
          <div class="contact-field">
            <label for="contact-signal" class="contact-label">Your Signal (email)</label>
            <input
              type="email"
              id="contact-signal"
              name="email"
              class="contact-input"
              required
            />
          </div>
          <div class="contact-field">
            <label for="contact-message" class="contact-label">Your Message</label>
            <textarea
              id="contact-message"
              name="message"
              class="contact-input contact-textarea"
              rows="5"
              required
            ></textarea>
          </div>
          <div class="contact-signal-wrap" id="contact-signal-wrap">
            <button type="submit" class="contact-submit signal-button signal-btn" id="contact-submit">
              <span>Send the Signal</span>
            </button>
            <div class="contact-confirm-symbol" aria-hidden="true">∞</div>
          </div>
          <p class="signal-confirmation" aria-live="polite" hidden>Signal received.</p>
        </form>
      </div>

      <div class="contact-pact">
        <p class="contact-pact-text contact-epilogue">
          You are not here by accident.<br />
          Every signal matters.<br />
          Every builder counts.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  (function () {
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("contact-submit");
    const channel = document.querySelector(".contact-channel");
    const confirmation = document.querySelector(".signal-confirmation");
    if (!form || !submitBtn || !channel) return;

    submitBtn.addEventListener("click", () => {
      submitBtn.classList.add("active");
      document.body.classList.add("cosmic-impact");

      setTimeout(() => {
        submitBtn.classList.remove("active");
        document.body.classList.remove("cosmic-impact");
      }, 1200);
    });

    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      submitBtn.disabled = true;
      if (confirmation instanceof HTMLElement) {
        confirmation.hidden = true;
        confirmation.textContent = "Signal received.";
        confirmation.classList.remove("signal-confirmation--error");
      }

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
        });
        const data = await res.json().catch(function () {
          return null;
        });

        if (!res.ok || !data || !data.ok) {
          const err =
            data && typeof data.error === "string"
              ? data.error
              : "Could not send your message.";
          if (confirmation instanceof HTMLElement) {
            confirmation.textContent = err;
            confirmation.classList.add("signal-confirmation--error");
            confirmation.hidden = false;
          }
          return;
        }

        submitBtn.classList.add("contact-submit-sent");
        const label = submitBtn.querySelector("span");
        if (label) label.textContent = "Signal received";
        if (confirmation instanceof HTMLElement) {
          confirmation.textContent = "Signal received.";
          confirmation.hidden = false;
        }
        form.reset();
      } catch {
        if (confirmation instanceof HTMLElement) {
          confirmation.textContent = "Network error. Please try again.";
          confirmation.classList.add("signal-confirmation--error");
          confirmation.hidden = false;
        }
      } finally {
        submitBtn.disabled = false;
      }
    });
  })();
</script>

<script>
  document.addEventListener("mousemove", (e) => {
    const x = (e.clientX / window.innerWidth - 0.5) * 6;
    const y = (e.clientY / window.innerHeight - 0.5) * 6;

    const bg = document.querySelector(".contact-bg");
    if (bg) {
      bg.style.transform = `translate(${x}px, ${y}px)`;
    }
  });
</script>

<script>
  (function () {
    const container = document.querySelector(".contact-page .cosmic-stars");
    if (!container) return;

    // Avoid duplicates (e.g. during hot reload)
    container.querySelectorAll(".star").forEach((n) => n.remove());

    for (let i = 0; i < 120; i++) {
      const star = document.createElement("span");
      star.className = "star";

      star.style.top = Math.random() * 100 + "%";
      star.style.left = Math.random() * 100 + "%";
      star.style.animationDelay = Math.random() * 6 + "s";
      star.style.animationDuration = 2 + Math.random() * 4 + "s";

      container.appendChild(star);
    }
  })();
</script>

<script>
  (function () {
    if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    function triggerCosmicPassage() {
      const el = document.querySelector(".contact-page .cosmic-passage");
      if (!el) return;

      el.style.animation = "none";
      void el.offsetWidth;
      el.style.animation = "cosmicPass 1.8s ease-out";

      const delay = 18000 + Math.random() * 10000; // 18s to 28s
      setTimeout(triggerCosmicPassage, delay);
    }

    triggerCosmicPassage();
  })();
</script>
