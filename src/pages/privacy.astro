---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Privacy Policy — FONE">

<section class="legal-page">
  <div class="container">

    <h1>Privacy Policy</h1>

    <p>
      FONE respects your privacy. This page explains what information may be collected
      when you interact with this website and how it is used.
    </p>

    <h2>Information we collect</h2>

    <p>
      When you use the contact form, you may voluntarily provide:
    </p>

    <ul>
      <li>Your name</li>
      <li>Your email address</li>
      <li>Your message</li>
    </ul>

    <p>
      This information is only used to respond to your message.
      It is never sold, rented, or shared with third parties.
    </p>

    <h2>Data storage</h2>

    <p>
      Messages sent through the website may be stored securely in order to
      respond to inquiries or maintain communication with members of the community.
    </p>

    <h2>Cookies</h2>

    <p>
      This website may use minimal technical cookies required for proper
      website functionality. No tracking cookies or advertising cookies are used.
    </p>

    <h2>Your rights</h2>

    <p>
      You have the right to request access, correction, or deletion of your
      personal information at any time.
    </p>

    <h2>Contact</h2>

    <p>
      If you have any questions regarding this privacy policy, you can contact us
      through the website contact form.
    </p>

    <p class="legal-note">
      Last updated: 2026
    </p>

  </div>
</section>

<style>

.legal-page{
  padding:120px 20px;
  max-width:900px;
  margin:auto;
}

.legal-page h1{
  font-size:42px;
  margin-bottom:40px;
}

.legal-page h2{
  margin-top:40px;
  margin-bottom:10px;
  font-size:22px;
}

.legal-page p{
  opacity:0.85;
  line-height:1.7;
}

.legal-page ul{
  margin:10px 0 20px 20px;
}

.legal-note{
  margin-top:60px;
  opacity:0.6;
}

</style>